APP_NAME="CaSe Sports Management"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Media storage (File Manager uploads, player photos, gallery, videos).
# Local development uses the "public" disk and needs no configuration.
# In production set MEDIA_DISK=r2 and fill in the Cloudflare R2 block below.
MEDIA_DISK=public
MEDIA_MAX_UPLOAD_KB=51200

# Cloudflare R2
# - R2_ENDPOINT is https://<ACCOUNT_ID>.r2.cloudflarestorage.com (no bucket).
# - Region is always "auto".
# - R2_URL is the bucket's public domain: a custom domain (recommended) or the
#   r2.dev development URL. This is what makes image URLs permanent and
#   cacheable, so keep it set for the public website.
# - For a fully private bucket, leave R2_URL empty and set MEDIA_SIGNED_URLS=true
#   to serve short-lived signed URLs instead.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
R2_URL=

MEDIA_SIGNED_URLS=false
MEDIA_SIGNED_URL_TTL=60

VITE_APP_NAME="${APP_NAME}"
